{
  "name": "convex-simple-auth",
  "version": "0.1.0",
  "description": "Minimal JWT-based email/password + anonymous auth for Convex. ~170 LoC, one dep (jose), no HTTP routes.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obask/convex-simple-auth.git"
  },
  "files": [
    "dist",
    "scripts",
    "templates",
    "README.md"
  ],
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "bin": {
    "convex-simple-auth-keys": "scripts/setup-auth-keys.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "release": "bash scripts/release.sh"
  },
  "peerDependencies": {
    "convex": ">=1.20.0",
    "jose": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "convex": "^1.39.0",
    "jose": "^6.0.0",
    "react": "^19.0.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.0.0"
}
